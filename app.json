{
  "expo": {
    "name": "HomeschoolHub",
    "slug": "homeschoolhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8DEFF"
    },
    "scheme": "homeschoolhubmobile",
    "assetBundlePatterns": [
      "**/*"
    ],
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#B8A4E8",
      "androidMode": "default",
      "androidCollapsedTitle": "New from HomeschoolHub"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tajamoxey.homeschoolhub",
      "buildNumber": "23",
      "infoPlist": {
        "UIRequiresFullScreen": true,
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown"
        ],
        "NSCameraUsageDescription": "HomeschoolHub needs camera access to capture photos of lessons and activities.",
        "NSPhotoLibraryUsageDescription": "HomeschoolHub needs photo library access to attach photos to lessons.",
        "NSPhotoLibraryAddUsageDescription": "HomeschoolHub needs permission to save photos to your library.",
        "NSUserNotificationsUsageDescription": "HomeschoolHub sends gentle reminders to help you stay on track with lessons and goals.",
        "NSUserTrackingUsageDescription": "We use this to provide you with personalized educational recommendations and improve your experience.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "icon": "./assets/icon.png",
      "package": "com.tajamoxey.homeschoolhub",
      "versionCode": 23,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "HomeschoolHub needs access to your photos to attach them to lessons.",
          "cameraPermission": "HomeschoolHub needs camera access to take photos of lessons."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#B8A4E8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "005bced9-b409-4feb-9430-39cef43a01d7"
      }
    }
  }
}
